PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=travelah
JWT_SECRET=change-this-to-a-long-random-string

# Public URL of the React app (invite + password reset links)
CLIENT_URL=http://localhost:3000

# Optional — password reset email (skip for FYP: reset opens on-screen automatically)
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=you@gmail.com SMTP_PASS=app-password SMTP_FROM=Travelah <you@gmail.com>
# Resend: RESEND_API_KEY=re_xxx RESEND_FROM=Travelah <noreply@yourdomain.com>

# Google OAuth — Sign in with Google (Web client ID from Google Cloud Console)
# Create OAuth 2.0 Client ID (Web application); add http://localhost:3000 to authorized JavaScript origins
GOOGLE_OAUTH_CLIENT_ID=

# Enable "Places API (New)" and "Maps JavaScript API" for this key in Google Cloud Console
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_DELAY_MS=250

# OSM opening hours (Nominatim + Overpass) — free, no API key required
# OSM_USER_AGENT=Travelah-FYP/1.0 (your-email@example.com)
# OSM_ENRICH_DELAY_MS=1100
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# AI Concierge — natural-language trip planning (homepage chat).
# Get a FREE key from Google AI Studio: https://aistudio.google.com/app/apikey
# Create the key on "Default Gemini Project" (not a billing-blocked project).
# The free tier is enough for development/demo. Leave blank to disable the chat.
GEMINI_API_KEY=
# Model for concierge + structured JSON parsing (generateContent API).
# Recommended on Default Gemini Project free tier:
#   gemini-3.1-flash-lite — 15 RPM / 500 RPD; multilingual + JSON schema (best for FYP)
#   gemini-2.5-flash      — 5 RPM / 20 RPD; use if 3.1-lite quality is not enough
#   gemini-2.5-flash-lite — 10 RPM / 20 RPD
# Avoid gemini-2.0-* on free tier in Malaysia — often shows 0 quota in AI Studio.
GEMINI_MODEL=gemini-3.1-flash-lite

# Cloudflare R2 — bulk upload scripts + runtime profile avatar uploads
R2_BUCKET=travelah-posts
# Full S3 API URL from bucket Settings (e.g. https://xxxx.r2.cloudflarestorage.com)
R2_ENDPOINT_URL=
# Optional fallback if you only have the account ID from R2 overview
R2_ACCOUNT_ID=
# S3 API credentials (same keys as `aws configure` for upload:r2 scripts)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public bucket URL (e.g. https://pub-xxxx.r2.dev) — also set VITE_R2_PUBLIC_URL in client/.env
R2_PUBLIC_URL=
