# Same Web client ID as server GOOGLE_OAUTH_CLIENT_ID (optional — client can also read /api/auth/config)
VITE_GOOGLE_CLIENT_ID=

# Cloudflare R2 public bucket URL (Settings → Public Development URL on the bucket)
# When set, /images/, /posts/, /places/, and /avatars/ paths resolve to this CDN instead of local public/
VITE_R2_PUBLIC_URL=
